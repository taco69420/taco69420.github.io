---
// GDPR Cookie Consent Banner
// - Accept: stores consent in localStorage, dynamically loads analytics
// - Decline: no storage of any kind; banner reappears on next visit
// - Analytics scripts are never present in the DOM until consent is given
---

<div
  id="gdpr-banner"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie consent"
  style="display:none;position:fixed;bottom:0;left:0;right:0;z-index:9999;background:#18181b;border-top:2px solid #3f3f46;padding:1rem 1.5rem;color:#e4e4e7;box-shadow:0 -4px 24px rgba(0,0,0,0.4);"
>
  <div style="max-width:800px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;gap:1rem;justify-content:space-between;">
    <p style="margin:0;font-size:0.875rem;line-height:1.6;flex:1;min-width:240px;">
      This site uses cookies and analytics to understand how visitors use it.
      No tracking scripts run until you click&nbsp;<strong>Accept</strong>.
      If you click <strong>Decline</strong>, nothing is stored and no cookies are set.
      <a href="/privacy" style="color:#10b981;font-weight:600;">Privacy Policy</a>
      &middot;
      <a href="/privacy#do-not-sell" style="color:#10b981;font-weight:600;">Do Not Sell My Info</a>
    </p>
    <div style="display:flex;gap:0.75rem;flex-shrink:0;">
      <button
        id="gdpr-decline"
        type="button"
        style="padding:0.5rem 1.25rem;border-radius:6px;border:2px solid #52525b;background:transparent;color:#a1a1aa;font-size:0.875rem;font-weight:600;cursor:pointer;"
      >
        Decline
      </button>
      <button
        id="gdpr-accept"
        type="button"
        style="padding:0.5rem 1.25rem;border-radius:6px;border:none;background:#10b981;color:#fff;font-size:0.875rem;font-weight:600;cursor:pointer;"
      >
        Accept
      </button>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    var STORAGE_KEY = 'gdpr-consent';
    var GA_ID = 'G-WGL40V0V8V';

    function loadAnalytics() {
      if (window.__gdprAnalyticsLoaded) return;
      window.__gdprAnalyticsLoaded = true;

      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      document.head.appendChild(s);

      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      window.gtag = gtag;
      gtag('js', new Date());
      gtag('config', GA_ID);
    }

    var banner = document.getElementById('gdpr-banner');
    var acceptBtn = document.getElementById('gdpr-accept');
    var declineBtn = document.getElementById('gdpr-decline');

    // If already accepted in a previous session, load analytics silently
    try {
      if (localStorage.getItem(STORAGE_KEY) === 'accepted') {
        loadAnalytics();
        return; // banner stays hidden
      }
    } catch (_) {}

    // Show banner — no prior consent found (or Decline was clicked before)
    banner.style.display = 'block';

    acceptBtn.addEventListener('click', function () {
      try { localStorage.setItem(STORAGE_KEY, 'accepted'); } catch (_) {}
      banner.style.display = 'none';
      loadAnalytics();
    });

    declineBtn.addEventListener('click', function () {
      // Store nothing. Banner will reappear on the next visit.
      banner.style.display = 'none';
    });
  })();
</script>
