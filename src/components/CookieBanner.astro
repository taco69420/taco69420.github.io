<div
  id="ccpa-cookie-banner"
  class="fixed inset-x-0 bottom-0 z-50 border-t border-zinc-700 bg-zinc-900/95 px-4 py-4 text-zinc-100 shadow-2xl backdrop-blur sm:px-6"
>
  <div class="mx-auto flex w-full max-w-5xl flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm leading-6 text-zinc-200">
      We use cookies and similar technologies to improve site performance and personalize your experience.
      By clicking Accept, you consent to these uses.
      <a href="/privacy" class="font-semibold text-[#D97706] underline-offset-2 hover:underline">Privacy Policy</a>
      ·
      <a href="/privacy#do-not-sell" class="font-semibold text-zinc-100 underline underline-offset-2 hover:text-zinc-300">
        Do Not Sell or Share My Personal Information
      </a>
    </p>

    <button
      id="accept-cookies"
      type="button"
      class="w-full rounded-md bg-[#0F766E] px-4 py-2 text-sm font-semibold text-white transition hover:bg-[#115e59] sm:w-auto"
    >
      Accept
    </button>
  </div>
</div>

<script is:inline>
  const storageKey = 'ccpa-cookie-consent';
  const banner = document.getElementById('ccpa-cookie-banner');
  const acceptButton = document.getElementById('accept-cookies');

  if (localStorage.getItem(storageKey) === 'accepted') {
    banner?.classList.add('hidden');
  }

  acceptButton?.addEventListener('click', () => {
    localStorage.setItem(storageKey, 'accepted');
    banner?.classList.add('hidden');
  });
</script>
