---
import CookieBanner from '../components/CookieBanner.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  schemas?: Record<string, unknown>[];
}

const {
  title,
  description = "Expert gopher trapping advice and gear reviews from Mark the Bagger. Serving Redlands, CA with field-tested methods since 2022.",
  ogImage = "/taco.jpg",
  schemas = [],
} = Astro.props;

const canonicalURL = Astro.url.href;
const siteURL = "https://howtokillgophers.com";
const fullOgImage = ogImage.startsWith("http") ? ogImage : siteURL + ogImage;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Mark the Bagger",
  "image": "https://howtokillgophers.com/taco.jpg",
  "@id": "https://howtokillgophers.com",
  "url": "https://howtokillgophers.com",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Redlands",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 34.0556,
    "longitude": -117.1825
  },
  "description": "Expert gopher trapping advice and gear reviews from Mark the Bagger, serving Redlands, CA since 2022.",
  "openingHours": "Mo-Su 00:00-23:59"
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:site_name" content="How To Kill Gophers" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <style>
      body { font-family: system-ui, sans-serif; background: #f4f4f5; color: #18181b; max-width: 800px; margin: 0 auto; padding: 2rem; line-height: 1.6; }
      header { border-bottom: 2px solid #e4e4e7; padding-bottom: 1rem; margin-bottom: 2rem; }
      h1 { color: #065f46; font-size: 2.5rem; margin-bottom: 0.2rem; }
      .subtitle { color: #52525b; font-size: 1.2rem; margin-top: 0; }
      .card { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 2rem; border: 1px solid #e4e4e7; }
      h2 { color: #047857; margin-top: 0; }
      .btn { display: inline-block; background: #10b981; color: white; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 1rem; transition: background 0.2s; }
      .btn:hover { background: #059669; }
      .disclaimer { border-top: 1px solid #e4e4e7; padding-top: 1rem; margin-top: 3rem; font-size: 0.85rem; color: #71717a; text-align: center; }
      nav { display: flex; gap: 15px; margin-bottom: 2rem; flex-wrap: wrap; }
      nav a { text-decoration: none; color: #18181b; font-weight: bold; padding: 8px 16px; background: #e4e4e7; border-radius: 6px; }
      nav a:hover { background: #d4d4d8; }
      .legal-link { color: #047857; text-decoration: none; font-weight: bold; }
      .legal-link:hover { text-decoration: underline; }
      .breadcrumb { font-size: 0.85rem; color: #71717a; margin-bottom: 1.5rem; display: block; }
      .breadcrumb a { color: #047857; text-decoration: none; padding: 0; background: none; border-radius: 0; font-weight: normal; }
      .breadcrumb a:hover { background: none; text-decoration: underline; }

      @media (max-width: 640px) {
        body { padding: 1rem; }
      }
    </style>

    <Fragment set:html={[localBusinessSchema, ...schemas].map((s) => `<script type="application/ld+json">${JSON.stringify(s)}</script>`).join('')} />
  </head>

  <body>
    <nav aria-label="Main navigation">
      <a href="/">Home</a>
      <a href="/methods">The Playbook</a>
      <a href="/problems">Problems</a>
      <a href="/traps">The Armory</a>
      <a href="/gopher-vs-mole">Gopher vs Mole</a>
      <a href="/seasons">Seasons</a>
      <a href="/faq">FAQ</a>
      <a href="/about">About Mark</a>
    </nav>

    <slot />

    <footer class="disclaimer">
      <p><strong>Affiliate Disclosure:</strong> I participate in the Amazon Services LLC Associates Program. As an Amazon Associate I earn from qualifying purchases.</p>
      <p style="margin-top: 10px;"><a href="/privacy" class="legal-link">Read the full Privacy Policy & Legal Disclaimers</a></p>
      <p style="margin-top: 10px;"><a href="/privacy#do-not-sell" class="legal-link">Do Not Sell or Share My Personal Information</a></p>
    </footer>

    <CookieBanner />
  </body>
</html>
