---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    
    <meta name="title" content="How To Kill Gophers | Mark The Bagger" />
    <meta name="description" content="Expert gopher trapping advice and gear reviews from Mark the Bagger. Serving Redlands, CA with field-tested methods since 2022." />
    <meta name="keywords" content="gopher trapping Redlands, how to kill gophers, Mark the Bagger, Victor gopher traps" />
    
    <style>
      body { font-family: system-ui, sans-serif; background: #f4f4f5; color: #18181b; max-width: 800px; margin: 0 auto; padding: 2rem; line-height: 1.6; }
      header { border-bottom: 2px solid #e4e4e7; padding-bottom: 1rem; margin-bottom: 2rem; }
      h1 { color: #065f46; font-size: 2.5rem; margin-bottom: 0.2rem; }
      .subtitle { color: #52525b; font-size: 1.2rem; margin-top: 0; }
      .card { background: white; padding: 1.5rem; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); margin-bottom: 2rem; border: 1px solid #e4e4e7; }
      h2 { color: #047857; margin-top: 0; }
      .btn { display: inline-block; background: #10b981; color: white; padding: 0.75rem 1.5rem; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 1rem; transition: background 0.2s; }
      .btn:hover { background: #059669; }
      .disclaimer { border-top: 1px solid #e4e4e7; padding-top: 1rem; margin-top: 3rem; font-size: 0.85rem; color: #71717a; text-align: center; }
      nav { display: flex; gap: 15px; margin-bottom: 2rem; flex-wrap: wrap; }
      nav a { text-decoration: none; color: #18181b; font-weight: bold; padding: 8px 16px; background: #e4e4e7; border-radius: 6px; }
      nav a:hover { background: #d4d4d8; }
      .legal-link { color: #047857; text-decoration: none; font-weight: bold; }
      .legal-link:hover { text-decoration: underline; }
    </style>

    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "name": "Mark the Bagger",
      "image": "https://howtokillgophers.com/taco.jpg",
      "@id": "https://howtokillgophers.com",
      "url": "https://howtokillgophers.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Redlands",
        "addressRegion": "CA",
        "addressCountry": "US"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 34.0556,
        "longitude": -117.1825
      },
      "description": "Expert gopher trapping advice and gear reviews from Mark the Bagger, serving Redlands, CA since 2022.",
      "openingHours": "Mo-Su 00:00-23:59"
    }
    </script>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.8/dist/cookieconsent.css" />
    <script src="https://cdn.jsdelivr.net/gh/orestbida/cookieconsent@3.0.8/dist/cookieconsent.umd.js"></script>

    <script type="text/plain" data-category="analytics" async src="https://www.googletagmanager.com/gtag/js?id=G-WGL40V0V8V"></script>
    
    <script is:inline>
      window.addEventListener('load', () => {
        if (!window.CookieConsent) return;

        CookieConsent.run({
          manageScriptTags: true,
          guiOptions: {
            consentModal: { layout: 'box', position: 'middle center', equalWeightButtons: true },
            preferencesModal: { layout: 'box', position: 'right', equalWeightButtons: true }
          },
          categories: {
            necessary: { enabled: true, readOnly: true },
            analytics: {}
          },
          language: {
            default: 'en',
            translations: {
              en: {
                consentModal: {
                  title: 'Your Privacy Choices',
                  description: 'We use cookies to improve site performance. Analytics cookies remain off until you click Accept.',
                  acceptAllBtn: 'Accept',
                  acceptNecessaryBtn: 'Reject non-essential',
                  showPreferencesBtn: 'Manage preferences',
                  footer: '<a href="/privacy" style="color:#D97706;font-weight:600;">Privacy Policy</a> · <a href="/privacy#do-not-sell" style="color:#D97706;font-weight:600;">Do Not Sell or Share My Personal Information</a>'
                },
                preferencesModal: {
                  title: 'Consent Preferences',
                  acceptAllBtn: 'Accept all',
                  acceptNecessaryBtn: 'Reject non-essential',
                  savePreferencesBtn: 'Save preferences',
                  sections: [
                    { title: 'Strictly Necessary', description: 'Required for the site to function.', linkedCategory: 'necessary' },
                    { title: 'Analytics', description: 'Help us understand site usage.', linkedCategory: 'analytics' },
                    {
                      title: 'More information',
                      description: 'Read our <a href="/privacy" class="cc__link">Privacy Policy</a> or use <a href="/privacy#do-not-sell" class="cc__link">Do Not Sell or Share My Personal Information</a>.'
                    }
                  ]
                }
              }
            }
          }
        });
      });
    </script>

    <style is:inline>
      #cc-main {
        --cc-bg: #18181b;
        --cc-primary-color: #D97706;
        --cc-secondary-color: #0F766E;
        --cc-btn-primary-bg: #0F766E;
        --cc-btn-primary-hover-bg: #0d635d;
        --cc-btn-primary-color: #ffffff;
        --cc-btn-secondary-bg: #D97706;
        --cc-btn-secondary-hover-bg: #b45309;
        --cc-btn-secondary-color: #ffffff;
        --cc-link-color: #D97706;
      }
    </style>

    <script type="text/plain" data-category="analytics" is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-WGL40V0V8V');
    </script>
  </head>
  
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/methods">The Playbook</a>
      <a href="/traps">The Armory</a>
      <a href="/about">About Mark</a>
    </nav>

    <slot />

    <footer class="disclaimer">
      <p><strong>Affiliate Disclosure:</strong> I participate in the Amazon Services LLC Associates Program. As an Amazon Associate I earn from qualifying purchases.</p>
      <p style="margin-top: 10px;"><a href="/privacy" class="legal-link">Read the full Privacy Policy & Legal Disclaimers</a></p>
    </footer>
  </body>
</html>
