---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const methods = await getCollection('methods');

const bySlug = Object.fromEntries(methods.map(m => [m.slug, m]));

const groups = [
  {
    label: 'Active Removal',
    id: 'active-removal',
    description: 'Lethal and hands-on methods for eliminating gophers that are already in your yard.',
    slugs: ['victor-traps', 'cinch-traps', 'dog-hunting', 'flooding-tactics'],
  },
  {
    label: 'Chemical & Fumigation',
    id: 'chemical-fumigation',
    description: 'Faster kill methods for larger infestations — higher risk, higher stakes.',
    slugs: ['carbon-monoxide', 'poison-bait-stations'],
  },
  {
    label: 'Barriers & Prevention',
    id: 'barriers-prevention',
    description: 'Stop gophers from getting in. Best installed before planting or during a rebuild.',
    slugs: ['gopher-mesh', 'exclusion-fencing', 'gopher-resistant-plants', 'barn-owl-box'],
  },
  {
    label: 'Repellents, Deterrents & Pro Help',
    id: 'repellents-pro',
    description: 'Supplementary tools and when to hand it off to someone else.',
    slugs: ['castor-oil', 'sonic-stakes', 'hiring-a-pro'],
  },
];

const difficultyColor = { easy: '#047857', medium: '#b45309', hard: '#b91c1c' };
const riskColor = { low: '#047857', medium: '#b45309', high: '#b91c1c' };
const costColor = { low: '#047857', medium: '#b45309', high: '#b91c1c' };

const startPicks = [
  { slug: 'victor-traps', cta: 'Most reliable first trap →' },
  { slug: 'cinch-traps', cta: 'Good beginner alternative →' },
  { slug: 'gopher-mesh', cta: 'Permanent prevention →' },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the most effective gopher control method?", "acceptedAnswer": { "@type": "Answer", "text": "Mechanical trapping — either Victor (Macabee) or Cinch-style traps — is the most reliable method for active infestations. Traps work directly in the main tunnel, require no chemicals, and give immediate results." } },
    { "@type": "Question", "name": "Do gopher repellents actually work?", "acceptedAnswer": { "@type": "Answer", "text": "Repellents like castor oil and sonic stakes can discourage gophers at the perimeter but won't stop an active infestation or a breeding surge. Use them to hold ground after trapping, not as a primary fix." } },
    { "@type": "Question", "name": "What is the difference between Victor traps and Cinch traps?", "acceptedAnswer": { "@type": "Answer", "text": "Both are main-run mechanical traps. Victor traps use a wire pinch mechanism and are the classic Macabee style. Cinch traps use a scissor-jaw design that many find easier to set and less prone to misfiring." } },
    { "@type": "Question", "name": "How long does gopher control take?", "acceptedAnswer": { "@type": "Answer", "text": "A single gopher can be caught within 24–48 hours with a properly placed trap. If you're dealing with multiple gophers or a yard-wide infestation, plan for 1–3 weeks of active trapping to clear the population." } },
  ]
};
---

<Layout
  title="Gopher Control Methods & Tactics (2026) | Mark The Bagger"
  description="Field-tested gopher control methods from easy repellents to advanced burrow fumigation. Mark the Bagger's step-by-step playbook for eliminating gophers from your yard."
  schemas={[faqSchema]}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> › Gopher Control Methods
  </nav>

  <header>
    <h1>The Playbook</h1>
    <p class="subtitle">13 field-tested methods — from first trap to full perimeter defense.</p>
    <p style="font-size: 0.8rem; color: #9ca3af; margin-top: 0.25rem;">Updated March 2026</p>
  </header>

  <main>

    <section class="card start-picks">
      <h2>Not sure where to start?</h2>
      <p style="margin-top: 0; color: #52525b; font-size: 0.95rem;">Most people with a fresh gopher problem should start with one of these three.</p>
      <div class="picks-grid">
        {startPicks.map(({ slug, cta }) => {
          const m = bySlug[slug];
          if (!m) return null;
          return (
            <a href={`/methods/${slug}`} class="pick-card">
              <strong>{m.data.title}</strong>
              <p>{m.data.description}</p>
              <span class="pick-cta">{cta}</span>
            </a>
          );
        })}
      </div>
    </section>

    <nav class="card" style="border-left: 4px solid #059669; padding: 1rem 1.5rem;">
      <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin: 0 0 0.65rem;">In This Guide</p>
      <ul style="margin: 0; padding-left: 1.1rem; line-height: 1.9; font-size: 0.9rem;">
        <li><a href="#active-removal">Active Removal</a></li>
        <li><a href="#chemical-fumigation">Chemical &amp; Fumigation</a></li>
        <li><a href="#barriers-prevention">Barriers &amp; Prevention</a></li>
        <li><a href="#repellents-pro">Repellents, Deterrents &amp; Pro Help</a></li>
        <li><a href="#faq">Frequently Asked Questions</a></li>
      </ul>
    </nav>

    <div class="card" style="background: #f0fdf4; border: 1.5px solid #6ee7b7; border-left: 4px solid #059669; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
      <div>
        <strong style="display: block; color: #065f46; font-size: 1rem; margin-bottom: 0.3rem;">Not sure which method fits your situation?</strong>
        <p style="margin: 0; font-size: 0.9rem; color: #374151;">Answer 3 questions. I'll send you straight to the right fix.</p>
      </div>
      <a href="/quiz" class="btn" style="margin-top: 0; flex-shrink: 0;">Take the quiz →</a>
    </div>

    {groups.map(group => (
      <section class="method-group">
        <h2 id={group.id} class="group-label">{group.label}</h2>
        <p class="group-desc">{group.description}</p>
        <div class="method-grid">
          {group.slugs.map(slug => {
            const m = bySlug[slug];
            if (!m) return null;
            const isHighRisk = m.data.petRisk === 'high';
            return (
              <article class={`method-card${isHighRisk ? ' method-card-danger' : ''}`}>
                {isHighRisk && <div class="danger-flag">⚠ High Pet Risk</div>}
                <h3>{m.data.title}</h3>
                <p>{m.data.description}</p>
                <div class="badge-row">
                  <span class="badge" style={`background: ${difficultyColor[m.data.difficulty]}`}>{m.data.difficulty}</span>
                  <span class="badge badge-outline" style={`color: ${riskColor[m.data.petRisk]}; border-color: ${riskColor[m.data.petRisk]}`}>
                    Pet: {m.data.petRisk}
                  </span>
                  <span class="badge badge-outline" style={`color: ${costColor[m.data.cost]}; border-color: ${costColor[m.data.cost]}`}>
                    Cost: {m.data.cost}
                  </span>
                </div>
                <div class="time-to-results">Results: {m.data.timeToResults}</div>
                <a href={`/methods/${slug}`} class="btn">Read the Guide</a>
              </article>
            );
          })}
        </div>
      </section>
    ))}

    <section class="card" style="margin-top: 2rem;">
      <h2 style="margin-top: 0;">Not a gopher?</h2>
      <p style="margin-bottom: 0;">Before you trap, make sure you have the right pest. <a href="/gopher-vs-mole">Check the Gopher vs Mole ID guide →</a></p>
    </section>

    <section class="card">
      <h2 id="faq">Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What is the most effective gopher control method?</summary>
          <p>Mechanical trapping — either Victor (Macabee) or Cinch-style traps — is the most reliable method for active infestations. Traps work directly in the main tunnel, require no chemicals, and give immediate results. See the <a href="/quick-start">Quick Start guide</a> for the exact process.</p>
        </details>
        <details class="faq-item">
          <summary>Do gopher repellents actually work?</summary>
          <p>Repellents like castor oil and sonic stakes can discourage gophers at the perimeter but won't stop an active infestation or a breeding surge. Use them to hold ground after trapping, not as a primary fix.</p>
        </details>
        <details class="faq-item">
          <summary>What is the difference between Victor traps and Cinch traps?</summary>
          <p>Both are main-run mechanical traps. Victor traps use a wire pinch mechanism and are the classic Macabee style. Cinch traps use a scissor-jaw design that many find easier to set and less prone to misfiring.</p>
        </details>
        <details class="faq-item">
          <summary>How long does gopher control take?</summary>
          <p>A single gopher can be caught within 24–48 hours with a properly placed trap. If you're dealing with multiple gophers or a yard-wide infestation, plan for 1–3 weeks of active trapping to clear the population.</p>
        </details>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Start picks */
  .picks-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    margin-top: 1rem;
  }

  .pick-card {
    display: flex;
    flex-direction: column;
    background: #f0fdf4;
    border: 1.5px solid #6ee7b7;
    border-radius: 8px;
    padding: 1rem 1.1rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .pick-card:hover {
    border-color: #10b981;
    box-shadow: 0 4px 12px rgba(16,185,129,0.12);
  }

  .pick-card strong {
    display: block;
    color: #065f46;
    font-size: 0.95rem;
    margin-bottom: 0.35rem;
  }

  .pick-card p {
    font-size: 0.85rem;
    color: #374151;
    margin: 0 0 0.75rem;
    flex: 1;
  }

  .pick-cta {
    font-size: 0.8rem;
    font-weight: 600;
    color: #047857;
  }

  /* Method groups */
  .method-group {
    margin-bottom: 2.5rem;
  }

  .group-label {
    font-size: 1.1rem;
    color: #065f46;
    margin-bottom: 0.2rem;
    border-bottom: 2px solid #e4e4e7;
    padding-bottom: 0.4rem;
  }

  .group-desc {
    color: #6b7280;
    font-size: 0.9rem;
    margin-top: 0.25rem;
    margin-bottom: 1rem;
  }

  .method-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .method-card {
    padding: 1.1rem;
    border: 1px solid #e4e4e7;
    border-radius: 8px;
    background: #fafafa;
    display: flex;
    flex-direction: column;
  }

  .method-card-danger {
    border-color: #fca5a5;
    background: #fff9f9;
  }

  .danger-flag {
    font-size: 0.75rem;
    font-weight: 700;
    color: #991b1b;
    margin-bottom: 0.5rem;
    letter-spacing: 0.02em;
  }

  .method-card h3 {
    margin-top: 0;
    margin-bottom: 0.35rem;
    font-size: 0.95rem;
    color: #18181b;
  }

  .method-card p {
    font-size: 0.85rem;
    color: #52525b;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .badge-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-bottom: 0.5rem;
  }

  .badge {
    display: inline-block;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
    color: white;
    font-weight: 700;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge-outline {
    background: transparent !important;
    border: 1.5px solid;
    font-weight: 600;
  }

  .time-to-results {
    font-size: 0.78rem;
    color: #9ca3af;
    margin-bottom: 0.75rem;
  }

  @media (max-width: 640px) {
    .picks-grid { grid-template-columns: 1fr; }
    .method-grid { grid-template-columns: 1fr; }
  }
</style>
