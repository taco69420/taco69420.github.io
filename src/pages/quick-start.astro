---
import Layout from '../layouts/Layout.astro';
import BrevoForm from '../components/BrevoForm.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Why isn't my gopher trap catching anything?", "acceptedAnswer": { "@type": "Answer", "text": "The most common reason is light entering the tunnel from the trap opening. Gophers sense the disruption and won't approach a trap that lets in daylight. Cover the hole completely with a dirt clod, board, or piece of sod — this single step is the difference between a trap that sits for days and one that catches within hours." } },
    { "@type": "Question", "name": "How do I find the gopher's main tunnel?", "acceptedAnswer": { "@type": "Answer", "text": "Probe in a semicircle 3–4 inches out from the mound edge. When the probe drops suddenly deeper, you've found the main run. The main tunnel is never directly under the mound — it runs alongside it. Rebar works fine for probing; a purpose-built probe just has better ergonomics." } },
    { "@type": "Question", "name": "Should I flood the burrow before trapping?", "acceptedAnswer": { "@type": "Answer", "text": "Only if you have a dog working the yard — flooding can push gophers to the surface where a hunting dog can catch them. Without a dog, skip the flooding and go straight to trapping. Either way, the gopher will come back to repair any tunnel damage, and that's exactly when they hit the trap." } },
    { "@type": "Question", "name": "How many traps should I set at once?", "acceptedAnswer": { "@type": "Answer", "text": "Set two traps back-to-back in the same main run section, facing in opposite directions. Two traps cover both directions of travel and double your chances of a quick catch." } },
  ]
};

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": "Quick Start Guide: How to Trap Gophers",
  "description": "Mark the Bagger's exact step-by-step gopher trapping process, field-tested over years with his dog Taco.",
  "step": [
    { "@type": "HowToStep", "name": "Scout the yard", "text": "Walk the whole yard first to get a general layout of where gopher activity is. Look for all the mounds before touching anything." },
    { "@type": "HowToStep", "name": "Open the mounds", "text": "Open up the holes where the actual mounds are." },
    { "@type": "HowToStep", "name": "Probe for the main run", "text": "Use a probe a few inches out from the mound in a semicircle pattern. You're feeling for the drop — when the probe sinks deeper, you've hit the main run." },
    { "@type": "HowToStep", "name": "Flush with water (dog owners only)", "text": "If you have a hunting dog, put a hose into the hole and flood it — this can push gophers toward the surface where the dog can catch them. No dog? Skip this step and go straight to trapping." },
    { "@type": "HowToStep", "name": "Set traps", "text": "Set Victor-style pinch traps back-to-back in pairs in the two best spots along the main run. Cover the hole completely — no light must enter the tunnel. The gopher will return to repair the damage and hit the trap." }
  ]
};
---

<Layout
  title="Quick Start Guide — How to Trap Gophers (2026) | How To Kill Gophers"
  description="Mark the Bagger's exact step-by-step gopher trapping process. Scout, probe, flush, and trap — the same method he ran with his dog Taco for years."
  schemas={[howToSchema, faqSchema]}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> › Quick Start
  </nav>

  <header class="mission-hero">
    <p class="mission-eyebrow">Field Briefing</p>
    <h1>The Taco Method: Start Here</h1>
    <p class="mission-sub">4 steps. No fluff. Scout, probe, flush (dog owners), trap. This is the process.</p>
    <p class="mission-dateline">Updated March 2026</p>
    <ol class="step-track" aria-label="Process steps">
      <li class="step-node"><span class="step-circle">1</span><span class="step-label">Scout</span></li>
      <li class="step-connector" aria-hidden="true"></li>
      <li class="step-node"><span class="step-circle">2</span><span class="step-label">Probe</span></li>
      <li class="step-connector" aria-hidden="true"></li>
      <li class="step-node"><span class="step-circle">3</span><span class="step-label">Flush</span></li>
      <li class="step-connector" aria-hidden="true"></li>
      <li class="step-node"><span class="step-circle">4</span><span class="step-label">Trap</span></li>
    </ol>
  </header>

  <main>

    <section class="card" style="border-left: 4px solid #10b981;">
      <p style="margin: 0; color: #374151; font-size: 0.95rem;">This is the actual process I used with my dog Taco for years — not a cleaned-up version, not generic advice. Every yard is different, but the sequence below works. I still run it in this exact order every time I work a new gopher problem.</p>
    </section>

    <nav class="card" aria-label="Table of contents" style="border-left: 4px solid #059669; padding: 1rem 1.5rem;">
      <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin: 0 0 0.65rem;">In This Guide</p>
      <ul style="margin: 0; padding-left: 1.1rem; line-height: 1.9; font-size: 0.9rem;">
        <li><a href="#step-1">Step 1 — Scout the yard</a></li>
        <li><a href="#step-2">Step 2 — Open the mounds (dog owners only)</a></li>
        <li><a href="#step-3">Step 3 — Probe for the main run</a></li>
        <li><a href="#step-4">Step 4 — Flush with water (dog owners only)</a></li>
        <li><a href="#step-5">Step 5 — Set traps</a></li>
        <li><a href="#no-light">The Secret — No Light in the Tunnel</a></li>
        <li><a href="#faq">Frequently Asked Questions</a></li>
      </ul>
    </nav>

    <section class="card">
      <h2 id="step-1">Step 1 — Scout the yard</h2>
      <p>Walk the whole yard first to get a general layout of where gopher activity is. Look for <em>all</em> the <a href="/problems/mound-id">mounds</a> before touching anything. Get the full picture first.</p>
      <p style="margin: 0; color: #6b7280; font-size: 0.9rem;">Rushing straight to the first mound you see is how you miss the bigger picture. Know your battlefield before you start.</p>
    </section>

    <section class="card">
      <h2 id="step-2">Step 2 — Open the mounds (dog owners only)</h2>
      <p>If you have a hunting dog, open the mound holes so the dog can sniff them and work the surface. Taco would occasionally nail a gopher right at the opening if one was close to the surface.</p>
      <p style="margin: 0; color: #6b7280; font-size: 0.9rem;"><strong>No dog?</strong> Leave the mounds alone. You don't need to open them — you'll dig a separate small access hole down to the main run in Step 3, set your traps, and cover it back up. The mound itself stays closed.</p>
    </section>

    <section class="card">
      <h2 id="step-3">Step 3 — Probe for the main run</h2>
      <p>Use a probe to poke around the area, a few inches out from the mound in a semicircle pattern. You're feeling for the drop — when the probe suddenly sinks deeper, you've hit the main tunnel run. <strong>The main run is never directly under the mound.</strong></p>
      <p>Rebar works fine. A purpose-built probe gives you better feedback and saves your wrist on hard ground.</p>
      <figure class="yt-short">
        <iframe
          width="315"
          height="560"
          src="https://www.youtube.com/embed/rktXf9k4lPU"
          title="Finding the gopher main run with a probe"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
        <figcaption>Exactly how I probe for the main run — the semicircle pattern and what the drop feels like when you find it.</figcaption>
      </figure>
      <figure class="yt-short">
        <iframe
          width="315"
          height="560"
          src="https://www.youtube.com/embed/ZCrJJejVtes"
          title="Opening up the gopher main run"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
          allowfullscreen
        ></iframe>
        <figcaption>Once you've found the run, this is how I open it up — what to dig, how big, and what you're looking for inside.</figcaption>
      </figure>
      <p style="margin: 0;"><a href="https://amzn.to/40JUZ3u" target="_blank" rel="sponsored noopener" style="color: #6b7280; font-size: 0.875rem;">→ Probe tools on Amazon</a></p>
    </section>

    <section class="card">
      <h2 id="step-4">Step 4 — Flush with water (dog owners only)</h2>
      <p><strong>Only do this step if you have a hunting dog working the yard.</strong> The point of flooding is to push gophers toward the surface where the dog can catch them. Taco was the reason we flooded — he'd work the yard while I ran the hose and we'd nail them as they came up.</p>
      <p style="margin: 0; color: #374151; font-size: 0.9rem;"><strong>No dog?</strong> Skip this step entirely and go straight to Step 5. You don't need to flood before trapping — and doing it without a dog just warns the gopher and muddies your trap set.</p>
    </section>

    <section class="card">
      <h2 id="step-5">Step 5 — Set traps</h2>
      <p>Set two steel pinch traps (Victor-style) back-to-back facing opposite directions in the main run. Cover the hole completely — no light in the tunnel. The gopher will come back to repair the damage and hit the trap. That's the whole game.</p>
      <figure class="trap-diagram">
        <img
          src="/diagrams/trap-set-diagram.svg"
          alt="Three-step diagram showing how to set Victor gopher traps: probe the surface, dig to the main run and set traps back-to-back facing both directions, then leave the mound closed"
          width="900"
          height="420"
        />
        <figcaption>Probe, dig to the run, set two traps facing opposite directions, cover the hole. Mound stays closed — gopher never knows you were there.</figcaption>
      </figure>
      <p style="margin: 0;"><a href="https://amzn.to/4cIJ64V" target="_blank" rel="sponsored noopener" style="color: #6b7280; font-size: 0.875rem;">→ Victor traps on Amazon</a> &nbsp;·&nbsp; <a href="/methods/victor-traps" style="color: #047857; font-weight: bold;">Full Victor trap guide →</a></p>
    </section>

    <section style="background: #fffbeb; border: 2px solid #f59e0b; border-radius: 10px; padding: 1.75rem; margin-bottom: 1.5rem;">
      <h2 id="no-light" style="color: #92400e; margin-top: 0; font-size: 1.15rem;">The Secret — No Light in the Tunnel</h2>
      <p style="color: #78350f; font-weight: 600; margin-top: 0;">This is the most important part of the whole process, and most people skip it.</p>
      <p style="color: #374151;">After setting the traps, there must be <strong>no visible light coming through the tunnel from the trap opening.</strong> Cover the hole completely. Block all light.</p>
      <p style="color: #374151;"><strong>Why it works:</strong> Gophers feel safe when their tunnel system appears intact and dark. If they see light, they know something is wrong and won't approach. But if the tunnel looks normal and dark, they'll come to investigate and repair the damage from the flooding — and that's when they hit the trap.</p>
      <p style="color: #374151; margin: 0;">Dirt clods, a board, a piece of sod — anything that seals out light. This one step is the difference between a trap that sits there for days doing nothing and one that catches within hours.</p>
    </section>

    <section class="card" style="border-left: 4px solid #e4e4e7;">
      <h2 style="font-size: 1.1rem; margin-top: 0;">Go deeper</h2>
      <p style="margin-bottom: 0.75rem; color: #6b7280; font-size: 0.9rem;">More detail on the gear and methods behind this process:</p>
      <p style="margin: 0;"><a href="/methods/victor-traps" style="color: #047857; font-weight: bold;">Victor Trap Deep Dive →</a> &nbsp;·&nbsp; <a href="/traps" style="color: #047857; font-weight: bold;">The Armory →</a></p>
    </section>

    <section class="card" style="border-left: 4px solid #f97316;">
      <p style="margin: 0; color: #374151; font-size: 0.9rem;">Seen people online recommending coffee grounds or Irish Spring? <a href="/what-doesnt-work" style="color: #047857; font-weight: 600;">Here's why that won't cut it</a> — and a rundown of every folk remedy I've tried and watched fail.</p>
    </section>

    <section class="card">
      <h2 id="faq">Frequently Asked Questions</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>Why isn't my gopher trap catching anything?</summary>
          <p>The most common reason is light entering the tunnel from the trap opening. Gophers sense the disruption and won't approach a trap that lets in daylight. Cover the hole completely with a dirt clod, board, or piece of sod — this single step is the difference between a trap that sits for days and one that catches within hours.</p>
        </details>
        <details class="faq-item">
          <summary>How do I find the gopher's main tunnel?</summary>
          <p>Probe in a semicircle 3–4 inches out from the mound edge. When the probe drops suddenly deeper, you've found the main run. The main tunnel is never directly under the mound — it runs alongside it. Rebar works fine for probing; a purpose-built probe just has better ergonomics.</p>
        </details>
        <details class="faq-item">
          <summary>Should I flood the burrow before trapping?</summary>
          <p>Only if you have a dog working the yard. Flooding pushes gophers toward the surface — useful when a hunting dog is there to catch them. Without a dog, skip it. Go straight to trapping. Either way, the gopher comes back to repair the tunnel and hits the trap.</p>
        </details>
        <details class="faq-item">
          <summary>How many traps should I set at once?</summary>
          <p>Set two traps back-to-back in the same main run section, facing in opposite directions. Two traps cover both directions of travel and double your chances of a quick catch.</p>
        </details>
      </div>
    </section>

    <BrevoForm />

  </main>
</Layout>

<style>
  /* ── Mission briefing hero ── */
  .mission-hero {
    background: #3b2a1a;
    color: #fdf6ee;
    padding: 2.25rem 2rem 2rem;
    border-radius: 8px;
    margin-bottom: 1.5rem;
  }

  .mission-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: #d4af37;
    margin: 0 0 0.65rem;
  }

  .mission-hero h1 {
    font-size: clamp(1.5rem, 4vw, 2rem);
    color: #fff8f0;
    margin: 0 0 0.75rem;
    line-height: 1.2;
  }

  .mission-sub {
    font-size: 1rem;
    color: #e8d5be;
    margin: 0 0 0.9rem;
    line-height: 1.65;
    max-width: 52ch;
  }

  .mission-dateline {
    font-size: 0.78rem;
    color: #a88060;
    margin: 0 0 1.75rem;
  }

  /* ── Step progress track ── */
  .step-track {
    display: flex;
    align-items: center;
    list-style: none;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
    gap: 0;
  }

  .step-node {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .step-circle {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: #d4af37;
    color: #1c1008;
    font-weight: 700;
    font-size: 0.85rem;
    display: flex;
    align-items: center;
    justify-content: center;
    line-height: 1;
  }

  .step-label {
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #c8a87a;
  }

  .step-connector {
    flex: 1;
    height: 2px;
    background: #6b4c2a;
    min-width: 1.25rem;
    max-width: 3rem;
    margin-bottom: 1.1rem;
    list-style: none;
  }

  @media (max-width: 480px) {
    .step-connector { min-width: 0.5rem; }
    .step-label { font-size: 0.62rem; }
  }

  /* ── Trap diagram ── */
  .trap-diagram {
    margin: 1.25rem 0;
  }

  .trap-diagram img {
    width: 100%;
    height: auto;
    border-radius: 6px;
    display: block;
  }

  .trap-diagram figcaption {
    font-size: 0.85rem;
    color: #6b7280;
    margin-top: 0.6rem;
    line-height: 1.5;
  }

  /* ── YouTube Short embed ── */
  .yt-short {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 1.25rem 0;
    gap: 0.75rem;
  }

  .yt-short iframe {
    border-radius: 8px;
    max-width: 100%;
  }

  .yt-short figcaption {
    font-size: 0.85rem;
    color: #6b7280;
    text-align: center;
    max-width: 315px;
    line-height: 1.5;
  }
</style>
