---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const methods = await getCollection('methods');

  return methods.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const contentH2s = headings.filter(h => h.depth === 2);

const relatedLinks: Record<string, Array<{label: string, url: string}>> = {
  'victor-traps': [
    { label: 'Cinch Trap Mainline Set', url: '/methods/cinch-traps' },
    { label: 'Quick Start Guide — full field process', url: '/quick-start' },
    { label: 'Keeping Pets Safe Around Gopher Control', url: '/problems/pet-safety' },
    { label: 'The Armory — gear picks', url: '/traps' },
  ],
  'cinch-traps': [
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Quick Start Guide — full field process', url: '/quick-start' },
    { label: 'Keeping Pets Safe Around Gopher Control', url: '/problems/pet-safety' },
  ],
  'gopher-mesh': [
    { label: 'Exclusion Fencing for Large Properties', url: '/methods/exclusion-fencing' },
    { label: 'Gopher-Resistant Plant Selection', url: '/methods/gopher-resistant-plants' },
    { label: 'Gopher-Proofing a New Yard', url: '/problems/new-yard-prep' },
    { label: 'Stopping Gopher Garden Destruction', url: '/problems/garden-destruction' },
  ],
  'flooding-tactics': [
    { label: 'Victor Trap Tunnel Intercept — follow-up after flooding', url: '/methods/victor-traps' },
    { label: 'Quick Start Guide — flooding is Step 4', url: '/quick-start' },
    { label: 'How to Identify Fresh Gopher Mounds', url: '/problems/mound-id' },
  ],
  'carbon-monoxide': [
    { label: 'Hiring a Professional Gopher Trapper', url: '/methods/hiring-a-pro' },
    { label: 'Victor Trap Tunnel Intercept — safer DIY alternative', url: '/methods/victor-traps' },
    { label: 'Keeping Pets Safe Around Gopher Control', url: '/problems/pet-safety' },
  ],
  'poison-bait-stations': [
    { label: 'Keeping Pets Safe Around Gopher Control', url: '/problems/pet-safety' },
    { label: 'Victor Trap Tunnel Intercept — safer alternative', url: '/methods/victor-traps' },
    { label: 'Cinch Trap Mainline Set — safer alternative', url: '/methods/cinch-traps' },
  ],
  'sonic-stakes': [
    { label: 'Victor Trap Tunnel Intercept — pair with for real results', url: '/methods/victor-traps' },
    { label: 'Castor Oil Soil Repellent Program', url: '/methods/castor-oil' },
    { label: 'Install Gopher Mesh Barriers — permanent fix', url: '/methods/gopher-mesh' },
  ],
  'castor-oil': [
    { label: 'Sonic Repeller Stakes — complementary repellent', url: '/methods/sonic-stakes' },
    { label: 'Victor Trap Tunnel Intercept — for actual elimination', url: '/methods/victor-traps' },
    { label: 'Install Gopher Mesh Barriers — permanent fix', url: '/methods/gopher-mesh' },
  ],
  'gopher-resistant-plants': [
    { label: 'Install Gopher Mesh Barriers', url: '/methods/gopher-mesh' },
    { label: 'Gopher-Proofing a New Yard', url: '/problems/new-yard-prep' },
    { label: 'Stopping Gopher Garden Destruction', url: '/problems/garden-destruction' },
  ],
  'exclusion-fencing': [
    { label: 'Install Gopher Mesh Barriers — smaller-scale barrier', url: '/methods/gopher-mesh' },
    { label: 'Gopher-Proofing a New Yard', url: '/problems/new-yard-prep' },
    { label: 'Barn Owl Box Installation — complementary prevention', url: '/methods/barn-owl-box' },
  ],
  'barn-owl-box': [
    { label: 'Gopher-Resistant Plant Selection', url: '/methods/gopher-resistant-plants' },
    { label: 'Exclusion Fencing for Large Properties', url: '/methods/exclusion-fencing' },
    { label: 'Castor Oil Soil Repellent Program', url: '/methods/castor-oil' },
  ],
  'dog-hunting': [
    { label: 'Quick Start Guide — Taco\'s role in the process', url: '/quick-start' },
    { label: 'Victor Trap Tunnel Intercept — follow-up after dog finds the run', url: '/methods/victor-traps' },
    { label: 'Keeping Pets Safe Around Gopher Control', url: '/problems/pet-safety' },
  ],
  'hiring-a-pro': [
    { label: 'Carbon Monoxide Burrow Treatment — most advanced DIY', url: '/methods/carbon-monoxide' },
    { label: 'Victor Trap Tunnel Intercept — DIY first option', url: '/methods/victor-traps' },
    { label: 'Underground Bait Station — DIY alternative', url: '/methods/poison-bait-stations' },
  ],
};

const related = relatedLinks[entry.slug] ?? [];

const siteURL = "https://howtokillgophers.com";
const pageURL = `${siteURL}/methods/${entry.slug}`;

const howToSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  "name": entry.data.title,
  "description": entry.data.description,
  "url": pageURL,
  "datePublished": entry.data.date.toISOString().split("T")[0],
  "author": {
    "@type": "Person",
    "name": "Mark the Bagger",
    "url": `${siteURL}/about`
  },
  "estimatedCost": {
    "@type": "MonetaryAmount",
    "currency": "USD",
    "value": entry.data.cost === "low" ? "0-20" : entry.data.cost === "medium" ? "20-80" : "80+"
  }
};

if (entry.data.updated) {
  howToSchema["dateModified"] = entry.data.updated.toISOString().split("T")[0];
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
    { "@type": "ListItem", "position": 2, "name": "Methods", "item": `${siteURL}/methods` },
    { "@type": "ListItem", "position": 3, "name": entry.data.title, "item": pageURL }
  ]
};
---

<Layout
  title={`${entry.data.title} (2026) | Gopher Control | Mark The Bagger`}
  description={entry.data.description}
  schemas={[howToSchema, breadcrumbSchema]}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/methods">Methods</a> › {entry.data.title}
  </nav>

  <header>
    <h1>{entry.data.title}</h1>
    <p class="subtitle">{entry.data.description}</p>
    <p style="font-size: 0.8rem; color: #9ca3af; margin-top: 0.25rem;">Updated March 2026</p>
  </header>

  {entry.data.petRisk === 'high' && (
    <div style="background: #fef2f2; border: 2px solid #fca5a5; border-left: 5px solid #dc2626; border-radius: 8px; padding: 1rem 1.25rem; margin-bottom: 1.5rem;">
      <strong style="color: #991b1b; font-size: 0.95rem;">&#9888; High Pet &amp; Wildlife Risk</strong>
      <p style="margin: 0.4rem 0 0; color: #7f1d1d; font-size: 0.9rem;">This method poses serious risk to dogs, cats, and wildlife. Keep pets away from treated areas. Read all label warnings before use. If you have pets, consider <a href="/methods/victor-traps" style="color: #991b1b;">Victor traps</a> or <a href="/methods/cinch-traps" style="color: #991b1b;">Cinch traps</a> instead.</p>
    </div>
  )}

  <section class="card">
    <h2>Quick Stats</h2>
    <ul>
      <li><strong>Difficulty:</strong> {entry.data.difficulty}</li>
      <li><strong>Pet Risk:</strong> {entry.data.petRisk}</li>
      <li><strong>Cost:</strong> {entry.data.cost}</li>
      <li><strong>Time to Results:</strong> {entry.data.timeToResults}</li>
    </ul>
  </section>

  {contentH2s.length >= 3 && (
    <nav class="card" style="border-left: 4px solid #059669; padding: 1rem 1.5rem;">
      <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin: 0 0 0.65rem;">In This Guide</p>
      <ul style="margin: 0; padding-left: 1.1rem; line-height: 1.9; font-size: 0.9rem;">
        {contentH2s.map(h => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
      </ul>
    </nav>
  )}

  <main class="card">
    <Content />
  </main>

  <section class="card" style="border-left: 4px solid #e4e4e7; padding: 1rem 1.5rem;">
    <h2 style="margin-bottom: 0.75rem; font-size: 1rem;">Also worth reading</h2>
    <ul style="margin-top: 0; padding-left: 1.2rem;">
      {related.map(link => <li><a href={link.url}>{link.label}</a></li>)}
    </ul>
    <p style="margin: 0.75rem 0 0;"><a href="/methods" style="color: #9ca3af; font-size: 0.85rem;">Browse all 13 methods →</a></p>
  </section>
</Layout>

<style is:global>
  .method-product-box {
    background: #f0fdf4;
    border: 1px solid #6ee7b7;
    border-left: 4px solid #059669;
    border-radius: 8px;
    padding: 1.1rem 1.25rem;
    margin: 1.25rem 0;
  }
  .mpb-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #059669;
    margin: 0 0 0.4rem;
  }
  .mpb-name {
    margin: 0 0 0.45rem;
    font-size: 1rem;
    color: #18181b;
  }
  .mpb-desc {
    font-size: 0.875rem;
    color: #374151;
    margin: 0 0 0.4rem;
    line-height: 1.55;
  }
  .mpb-best-for {
    font-size: 0.825rem;
    color: #374151;
    margin: 0 0 0.65rem;
    line-height: 1.5;
  }
  .mpb-best-for strong {
    color: #047857;
  }
  .mpb-btn {
    display: inline-block;
    background: #059669;
    color: white !important;
    padding: 0.5rem 1.1rem;
    text-decoration: none !important;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.825rem;
    border-bottom: none !important;
    transition: background 0.15s;
  }
  .mpb-btn:hover {
    background: #047857;
    color: white !important;
  }
</style>
