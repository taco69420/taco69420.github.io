---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the cheapest way to get rid of gophers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Victor pinch traps are the cheapest effective method — a 2-pack runs about $15 and you reuse them indefinitely. Set two back-to-back in the main run, block the light, check in 12 hours. Most single-gopher jobs are done for under $20 total."
      }
    },
    {
      "@type": "Question",
      "name": "How much does professional gopher trapping cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Residential gopher control runs $150 to $500+ depending on property size, method, and whether it's a one-time treatment or a recurring contract. Get at least two quotes — pricing varies wildly between operators."
      }
    },
    {
      "@type": "Question",
      "name": "Is gopher mesh worth the cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For vegetable gardens and raised beds, yes — it's the only method that provides permanent protection. Cost depends on square footage: a single 4x8 raised bed runs $30–60 in hardware cloth. A full lawn can run $500–1,500 installed. Install it before you plant, not after gophers show up."
      }
    },
    {
      "@type": "Question",
      "name": "Do sonic stakes actually work and are they worth buying?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonic stakes are cheap ($20–40 each) but the results are inconsistent. Gophers habituate to the vibration within days to weeks in most cases. They work best as a temporary deterrent while you're setting up a real control program — not as a standalone fix."
      }
    }
  ]
};
