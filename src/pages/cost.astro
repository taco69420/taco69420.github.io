              <th>Upfront Cost</th>
              <th>Ongoing Cost</th>
              <th>Reusable?</th>
              <th>DIY or Pro</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><a href="/methods/flooding-tactics">Flooding Active Runs</a></td>
              <td class="cost-free">$0</td>
              <td>$0</td>
              <td>—</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/dog-hunting">The Taco Method (Dog Hunting)</a></td>
              <td class="cost-free">$0 <span class="cost-note">if you have a dog</span></td>
              <td>$0</td>
              <td>—</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/victor-traps">Victor Trap Tunnel Intercept</a></td>
              <td class="cost-low">~$15 <span class="cost-note">2-pack</span></td>
              <td>$0</td>
              <td>Yes</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/poison-bait-stations">Underground Bait Station</a></td>
              <td class="cost-low">~$20–30</td>
              <td>~$15–25 <span class="cost-note">per refill</span></td>
              <td>Partial</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/sonic-stakes">Sonic Repeller Stakes</a></td>
              <td class="cost-low">~$20–40 each</td>
              <td>$0</td>
              <td>Yes</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/gopher-resistant-plants">Gopher-Resistant Plant Selection</a></td>
              <td class="cost-low">Varies</td>
              <td>Varies</td>
              <td>—</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/cinch-traps">Cinch Trap Mainline Set</a></td>
              <td class="cost-mid">~$30–35 each</td>
              <td>$0</td>
              <td>Yes</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/castor-oil">Castor Oil Repellent Program</a></td>
              <td class="cost-mid">~$20–40</td>
              <td>~$20–40 <span class="cost-note">per treatment</span></td>
              <td>No</td>
              <td>DIY</td>
            </tr>
            <tr>
              <td><a href="/methods/barn-owl-box">Barn Owl Box Installation</a></td>
              <td class="cost-mid">~$60–100</td>
