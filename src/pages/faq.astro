---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the fastest way to kill a gopher?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mechanical trapping with a cinch or Victor-style trap set in the main tunnel run. A correctly placed trap in an active run can catch a gopher within hours. No bait gimmicks, no waiting — just find the main run and set two traps back-to-back."
      }
    },
    {
      "@type": "Question",
      "name": "Do gophers come out above ground?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rarely. Gophers spend almost their entire life underground. You might catch one briefly poking out near a fresh mound to push soil, but they're not surface animals. If you're seeing a rodent running around your yard, it's probably a ground squirrel — not a gopher."
      }
    },
    {
      "@type": "Question",
      "name": "Will coffee grounds repel gophers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Coffee grounds, cayenne pepper, garlic, mothballs, and similar home remedies have no proven effect on gophers. They've been used underground their whole life — a weird smell isn't going to make them leave prime territory. Save your coffee for yourself and set a trap."
      }
    },
    {
      "@type": "Question",
      "name": "Do gopher repellers actually work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonic repeller stakes can push gophers out of a specific zone but won't eliminate them — they just relocate the problem to another part of your yard. Think of them as a fence, not a fix. Best used as a perimeter buffer while you actively trap the population."
      }
    },
    {
      "@type": "Question",
      "name": "What time of day are gophers most active?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gophers are most active in early morning and late afternoon, but they tunnel at all hours. Unlike squirrels, they don't have a strict above-ground schedule since they live underground. The good news: traps work 24/7 so timing doesn't matter much."
      }
    },
    {
      "@type": "Question",
      "name": "Can gophers chew through concrete?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No — their teeth can't handle solid concrete or rock. But they don't need to. Gophers undermine it by removing the soil underneath, which causes settling, sinking, and cracking over time. The tunneling is the weapon, not the teeth."
      }
    },
    {
      "@type": "Question",
      "name": "Do gophers live in colonies?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Gophers are solitary and fiercely territorial. Each tunnel system typically belongs to one animal. If you're seeing mounds spread across a wide area, it's usually one gopher with a large range — or multiple individual gophers holding separate territories side by side. Catching one doesn't clear the yard."
      }
    },
    {
      "@type": "Question",
      "name": "Will a gopher come back after you remove it?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The one you caught won't. But an empty tunnel system is prime real estate and neighboring gophers will move in within days — sometimes hours. Keep traps set for at least a week after your first catch and watch for new mound activity at the edges of the cleared zone."
      }
    },
    {
      "@type": "Question",
      "name": "Is it legal to kill gophers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In most U.S. states, yes. Pocket gophers are classified as pests, not protected wildlife, and can be legally trapped or baited on your own property. Always check local regulations before using rodenticides — some products require a pest control license to purchase or apply."
      }
    },
    {
      "@type": "Question",
      "name": "How deep do gopher tunnels go?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Main lateral runs are typically 6–18 inches deep. Nesting chambers and food caches can go down 2–6 feet. This is why shallow barriers, surface sprays, and most repellents fail — the gopher is just working below them."
      }
    },
    {
      "@type": "Question",
      "name": "How much does gopher control cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Victor-style pinch traps run about $15 for a 2-pack and are reusable indefinitely — most single-gopher jobs cost under $20. Gopher mesh for a raised bed runs $30–60. Professional trapping runs $150–500+ per job. See the full cost breakdown for every method."
      }
    },
    {
      "@type": "Question",
      "name": "Is it safe to trap gophers with dogs or kids in the yard?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Mechanical traps are the safest option with pets and kids around — no bait, no poison, no risk if a dog digs one up. Cinch traps are slightly more enclosed than Victor-style and a good choice if safety is a concern. Avoid poison bait stations entirely if you have dogs."
      }
    },
    {
      "@type": "Question",
      "name": "How do I know if a gopher mound is fresh and active?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A fresh mound has moist, loose soil that crumbles easily and a crescent or fan shape with a plugged hole off to one side. If the soil is dry and hard-packed, it's old spoil. Poke the plug — if it's soft and gives easily, the tunnel below is active. Set traps within 24 hours of spotting fresh mounds."
      }
    },
    {
      "@type": "Question",
      "name": "When is gopher season?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Spring (February–May) and fall (September–November) are the two peak activity windows. Spring is breeding season — mounds multiply fast. Fall is food-caching season — gophers expand tunnels aggressively. In Southern California, activity never fully stops. In colder regions, winter slows things down but doesn't eliminate activity."
      }
    },
    {
      "@type": "Question",
      "name": "Can gophers damage drip irrigation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — gophers chew through drip lines and emitters constantly. They follow moisture corridors underground, and drip tubing runs directly through their tunnel zones. If you're finding chewed lines with no obvious entry point, gophers are working below the surface. Trap the run first, then repair and sleeve the lines."
      }
    }
  ]
};
