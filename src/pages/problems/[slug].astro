---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const problems = await getCollection('problems');

  return problems.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content, headings } = await entry.render();
const contentH2s = headings.filter(h => h.depth === 2);

const relatedLinks: Record<string, Array<{label: string, url: string}>> = {
  'drip-emitter-damage': [
    { label: 'Gophers Chewing Irrigation Lines', url: '/problems/irrigation-damage' },
    { label: 'Victor Trap Tunnel Intercept — stop the repeat damage', url: '/methods/victor-traps' },
    { label: 'Install Gopher Mesh Barriers — protect emitter zones', url: '/methods/gopher-mesh' },
  ],
  'foundation-damage': [
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Flooding Active Gopher Runs — map the tunnel system', url: '/methods/flooding-tactics' },
    { label: 'Hiring a Professional Gopher Trapper', url: '/methods/hiring-a-pro' },
  ],
  'garden-destruction': [
    { label: 'Install Gopher Mesh Barriers — prevent next time', url: '/methods/gopher-mesh' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Gopher Damage in Vegetable Gardens', url: '/problems/vegetable-garden' },
  ],
  'irrigation-damage': [
    { label: 'Gophers Destroying Drip Emitters', url: '/problems/drip-emitter-damage' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Install Gopher Mesh Barriers — protect irrigation runs', url: '/methods/gopher-mesh' },
  ],
  'lawn-damage': [
    { label: 'How to Identify Fresh Gopher Mounds', url: '/problems/mound-id' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Quick Start Guide', url: '/quick-start' },
  ],
  'mound-id': [
    { label: 'Gopher vs Mole ID Guide', url: '/gopher-vs-mole' },
    { label: 'Quick Start Guide — once you know you have a gopher', url: '/quick-start' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
  ],
  'neighbor-disputes': [
    { label: 'Quick Start Guide — share this with your neighbor', url: '/quick-start' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Hiring a Professional Gopher Trapper', url: '/methods/hiring-a-pro' },
  ],
  'new-yard-prep': [
    { label: 'Install Gopher Mesh Barriers', url: '/methods/gopher-mesh' },
    { label: 'Exclusion Fencing for Large Properties', url: '/methods/exclusion-fencing' },
    { label: 'Gopher-Resistant Plant Selection', url: '/methods/gopher-resistant-plants' },
  ],
  'pet-safety': [
    { label: 'Victor Trap Tunnel Intercept — safest lethal method', url: '/methods/victor-traps' },
    { label: 'Cinch Trap Mainline Set', url: '/methods/cinch-traps' },
    { label: 'Underground Bait Station — what NOT to use with dogs', url: '/methods/poison-bait-stations' },
  ],
  'tree-shrub-damage': [
    { label: 'Install Gopher Mesh Barriers — root protection', url: '/methods/gopher-mesh' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
    { label: 'Hiring a Professional Gopher Trapper', url: '/methods/hiring-a-pro' },
  ],
  'vegetable-garden': [
    { label: 'Install Gopher Mesh Barriers — only permanent fix', url: '/methods/gopher-mesh' },
    { label: 'Stopping Gopher Garden Destruction', url: '/problems/garden-destruction' },
    { label: 'Victor Trap Tunnel Intercept', url: '/methods/victor-traps' },
  ],
};

const related = relatedLinks[entry.slug] ?? [];

const siteURL = "https://howtokillgophers.com";
const pageURL = `${siteURL}/problems/${entry.slug}`;

const articleSchema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "url": pageURL,
  "datePublished": entry.data.date.toISOString().split("T")[0],
  "author": {
    "@type": "Person",
    "name": "Mark the Bagger",
    "url": `${siteURL}/about`
  },
  "publisher": {
    "@type": "Organization",
    "name": "How To Kill Gophers",
    "url": siteURL
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageURL
  }
};

if (entry.data.updated) {
  articleSchema["dateModified"] = entry.data.updated.toISOString().split("T")[0];
}

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": siteURL },
    { "@type": "ListItem", "position": 2, "name": "Common Problems", "item": `${siteURL}/#problems` },
    { "@type": "ListItem", "position": 3, "name": entry.data.title, "item": pageURL }
  ]
};
---

<Layout
  title={`${entry.data.title} (2026) | Gopher Problems | Mark The Bagger`}
  description={entry.data.description}
  schemas={[articleSchema, breadcrumbSchema]}
>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a> › <a href="/#problems">Common Problems</a> › {entry.data.title}
  </nav>

  <header>
    <h1>{entry.data.title}</h1>
    <p class="subtitle">{entry.data.description}</p>
    <p class="dateline">Updated March 2026</p>
  </header>

  <section class="card">
    <h2>Quick Stats</h2>
    <ul>
      <li><strong>Difficulty:</strong> {entry.data.difficulty}</li>
      <li><strong>Pet Risk:</strong> {entry.data.petRisk}</li>
      <li><strong>Cost:</strong> {entry.data.cost}</li>
      <li><strong>Time to Results:</strong> {entry.data.timeToResults}</li>
    </ul>
  </section>

  {entry.slug === 'mound-id' && (
    <figure class="yt-short">
      <iframe
        width="315"
        height="560"
        src="https://www.youtube.com/embed/e7nfbjYB1oU"
        title="Identifying a fresh active gopher mound in Redlands"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
        allowfullscreen
      ></iframe>
      <figcaption>Fresh mound I found this morning in Redlands. Moist dirt, active tunnel — this is exactly what you're looking for before you start.</figcaption>
    </figure>
  )}

  {contentH2s.length >= 3 && (
    <nav class="card" aria-label="Table of contents" style="border-left: 4px solid #059669; padding: 1rem 1.5rem;">
      <p style="font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #6b7280; margin: 0 0 0.65rem;">In This Guide</p>
      <ul style="margin: 0; padding-left: 1.1rem; line-height: 1.9; font-size: 0.9rem;">
        {contentH2s.map(h => <li><a href={`#${h.slug}`}>{h.text}</a></li>)}
      </ul>
    </nav>
  )}

  <main class="card">
    <Content />
  </main>

  <section class="card related-section">
    <p class="related-label">Related guides</p>
    <div class="related-grid">
      {related.map(link => (
        <a href={link.url} class="related-card">{link.label} →</a>
      ))}
    </div>
    <p style="margin: 0.75rem 0 0;"><a href="/problems" style="color: #6b7280; font-size: 0.85rem;">Browse all 11 problem guides →</a></p>
  </section>
</Layout>

<style>
  .related-section {
    border-left: 4px solid #059669;
    padding: 1rem 1.5rem;
  }

  .related-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #6b7280;
    margin: 0 0 0.75rem;
  }

  .related-grid {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .related-card {
    display: block;
    background: #f0fdf4;
    border: 1px solid #6ee7b7;
    border-radius: 6px;
    padding: 0.6rem 0.9rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: #047857;
    text-decoration: none;
    transition: background 0.15s, border-color 0.15s;
  }

  .related-card:hover {
    background: #dcfce7;
    border-color: #34d399;
    text-decoration: none;
  }

  .yt-short {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin: 0 0 1.5rem;
    gap: 0.75rem;
  }

  .yt-short iframe {
    border-radius: 8px;
    max-width: 100%;
  }

  .yt-short figcaption {
    font-size: 0.85rem;
    color: #6b7280;
    text-align: center;
    max-width: 315px;
    line-height: 1.5;
  }
</style>
