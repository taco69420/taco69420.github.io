---
import Layout from '../layouts/Layout.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the best gopher trap?", "acceptedAnswer": { "@type": "Answer", "text": "Victor-style high-tension wire traps (Macabee pattern) are the most reliable for main tunnel intercept work. They're inexpensive, durable, and catch consistently when placed correctly in the main run." } },
    { "@type": "Question", "name": "Do I need bait on a gopher trap?", "acceptedAnswer": { "@type": "Answer", "text": "Bait isn't required, but a small dab of peanut butter behind the trigger plate increases commitment — the gopher pauses to investigate instead of pushing past the trigger without firing it." } },
    { "@type": "Question", "name": "When should I use gopher gassers instead of traps?", "acceptedAnswer": { "@type": "Answer", "text": "Gassers work best when you can't locate the active run in a deep, branching tunnel network. Seal every exit hole before lighting one, or you'll just fumigate your lawn for no effect." } },
    { "@type": "Question", "name": "Do I need a special probe, or can I use rebar?", "acceptedAnswer": { "@type": "Answer", "text": "Rebar from any hardware store does the exact same job as a purpose-built probe. A purpose-built probe just has better ergonomics and handle grip for longer sessions, but the technique is identical." } },
  ]
};
