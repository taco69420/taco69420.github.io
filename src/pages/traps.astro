          <tbody>
            <tr>
              <td><strong>Purpose-Built Probe</strong></td>
              <td><span class="tier-badge tier-mid">Mid</span></td>
              <td>Regular use, ergonomic handle, long sessions</td>
              <td><a href="https://amzn.to/4dlMbrU" class="table-btn" target="_blank" rel="sponsored noopener">Shop →</a></td>
